# ============================================================
# Task Planner Bot — Переменные окружения
# ============================================================
# Скопировать в .env и заполнить значения:
#   cp .env.example .env
# ============================================================

# === Telegram Bot ===
BOT_TOKEN=                        # Токен от @BotFather
ADMIN_USER_ID=0                   # Ваш Telegram ID (узнать у @userinfobot)

# === Webhook (только для продакшена) ===
WEBHOOK_URL=                      # https://yourdomain.com/webhook
WEBHOOK_SECRET=                   # Случайная строка: openssl rand -hex 32

# === База данных ===
DATABASE_URL=sqlite+aiosqlite:///./data/task_planner.db

# === URLs ===
API_BASE_URL=http://localhost:8000/api      # Для dev
FRONTEND_URL=http://localhost:5173          # Для dev
# Продакшен:
# API_BASE_URL=https://yourdomain.com/api
# FRONTEND_URL=https://your-project.pages.dev

# === Режим работы ===
DEFAULT_TIMEZONE=Europe/Moscow
USE_POLLING=true                  # true = dev (polling), false = prod (webhook)
DEBUG=true                        # true = dev, false = prod

# ============================================================
# Продакшен-конфигурация (пример):
# ============================================================
# BOT_TOKEN=123456:ABC-xxx
# ADMIN_USER_ID=123456789
# WEBHOOK_URL=https://planner.example.com/webhook
# WEBHOOK_SECRET=a1b2c3d4e5f6...
# DATABASE_URL=sqlite+aiosqlite:///./data/task_planner.db
# API_BASE_URL=https://planner.example.com/api
# FRONTEND_URL=https://task-planner.pages.dev
# DEFAULT_TIMEZONE=Europe/Moscow
# USE_POLLING=false
# DEBUG=false
# ============================================================

# === Cloudflare Pages (фронтенд) ===
# В Cloudflare Pages Dashboard → Settings → Environment Variables:
# VITE_API_URL=https://yourdomain.com/api
